{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "modules": [
    "title",
    "separator",
    "os",
    "kernel",
    "shell",
    "terminal",
    "cpu",
    "gpu",
    "memory",
    "swap",
    {
      "type": "disk",
      "key": "Disk",
      "folders": "/"
    },
    {
      "type": "disk",
      "key": "Home",
      "folders": "/home"
    },
    "battery",
    "break",
    "colors"
  ]
}
